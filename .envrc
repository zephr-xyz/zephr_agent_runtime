# Optional direnv integration for local development.
#
# This file intentionally does not run uv sync or build native dependencies.
# Bootstrap explicitly with:
#   uv sync
#   uv run prepare_platform_tools
#   uv run prepare_native_deps
#   uv run prepare_dev

export UV_PROJECT_ENVIRONMENT="$PWD/.venv"
PATH_add "$UV_PROJECT_ENVIRONMENT/bin"
